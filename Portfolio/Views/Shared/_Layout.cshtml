<!DOCTYPE html>
<html lang="en">

<head>

    <meta charset="utf-8" />

    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <meta http-equiv="X-UA-Compatible" content="IE=edge" />

    <title>Vikash Kumar | Full Stack .NET Developer</title>

    <meta name="description"
          content="Portfolio of Vikash Kumar, Full Stack .NET Developer specializing in ASP.NET Core, ASP.NET MVC, Web API, SQL Server, Microservices and Cloud Technologies." />

    <meta name="keywords"
          content="Vikash Kumar, Full Stack .NET Developer, ASP.NET Core, ASP.NET MVC, Web API, SQL Server, C#, Portfolio, Microservices" />

    <meta name="author"
          content="Vikash Kumar" />

    <meta name="theme-color"
          content="#2563eb" />

    <!-- SEO & Meta Tags (Step 15) -->
    <meta name="robots" content="index, follow" />
    <meta name="language" content="en" />
    <link rel="canonical" href="https://byvikashk.in/" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content="Vikash Kumar | Full Stack .NET Developer" />
    <meta property="og:description"
          content="Portfolio of Vikash Kumar, Full Stack .NET Developer specializing in ASP.NET Core, ASP.NET MVC, Web API, SQL Server, Microservices and Cloud Technologies." />
    <meta property="og:url" content="https://byvikashk.in/" />
    <meta property="og:image"
          content="https://byvikashk.in/images/logo.png" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="Vikash Kumar | Full Stack .NET Developer" />
    <meta name="twitter:description"
          content="Portfolio of Vikash Kumar, Full Stack .NET Developer specializing in ASP.NET Core, ASP.NET MVC, Web API, SQL Server, Microservices and Cloud Technologies." />
    <meta name="twitter:image"
          content="https://byvikashk.in/images/logo.png" />
    <!-- Apple Touch Icon -->
    <link rel="apple-touch-icon" href="~/images/logo.png" />

    <!-- Favicon -->

    <link rel="icon"
          type="image/png"
          href="~/images/logo.png" />

    <!-- Bootstrap -->

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.7/dist/css/bootstrap.min.css"
          rel="stylesheet">

    <!-- Bootstrap Icons -->

    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css"
          rel="stylesheet">

    <!-- Google Fonts -->

    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap"
          rel="stylesheet">

    <!-- CSS -->

    <link href="~/css/home.css"
          rel="stylesheet"
          asp-append-version="true" />

    <!-- Structured Data (JSON-LD) for SEO -->
    <script type="application/ld+json">
    {
      "@@context": "https://schema.org/",
      "@@type": "Person",
      "name": "Vikash Kumar",
      "url": "https://byvikashk.in/",
      "image": "https://byvikashk.in/images/logo.png",
      "jobTitle": "Full Stack .NET Developer",
      "description": "Passionate Full Stack .NET Developer with experience building enterprise web applications, RESTful APIs, cloud-integrated solutions, and scalable backend systems using Microsoft .NET technologies.",
      "sameAs": [
        "https://www.linkedin.com/in/byvikashk",
        "https://github.com/byvikashk",
        "https://leetcode.com/u/byvikashk"
      ],
      "knowsAbout": ["ASP.NET Core", "ASP.NET MVC", "C#", "Web API", "SQL Server", "JavaScript", "Bootstrap", "Google Cloud", "Git", "Azure DevOps", "Microservices"]
    }
    </script>
</head>

<body>

    <!-- Scroll Progress Bar (Step 13) -->
    <div id="scroll-progress" class="scroll-progress"></div>

    <!-- Page Loader -->
    <div id="page-loader" aria-hidden="true">
        <div class="loader-spinner" role="status" aria-label="Loading">
            <span class="visually-hidden">Loading...</span>
        </div>
    </div>

    <!-- Scroll To Top Button -->
    <button id="scroll-top" class="btn btn-primary" aria-label="Scroll to top" title="Scroll to top">
        <i class="bi bi-arrow-up"></i>
    </button>

    @RenderBody()

    <!-- AOS CSS -->
    <link href="https://cdn.jsdelivr.net/npm/aos@2.3.4/dist/aos.css" rel="stylesheet">

    <!-- Bootstrap -->

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.7/dist/js/bootstrap.bundle.min.js"></script>

    <!-- AOS JS -->
    <script src="https://cdn.jsdelivr.net/npm/aos@2.3.4/dist/aos.js"></script>

    <!-- Custom JS -->

    <script src="~/js/site.js"
            asp-append-version="true"></script>

</body>

</html>
